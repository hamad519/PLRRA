generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// -------------------------- USER --------------------------
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// -------------------------- EVENT --------------------------
model Event {
  id              Int       @id @default(autoincrement())
  title           String
  fromDate        DateTime
  toDate          DateTime
  date            DateTime?
  location        String
  mainImageBase64 String?   @db.LongText
  description     String    @default("") @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  registrations EventRegistration[]

  @@index([fromDate])
  @@map("events")
}

// -------------------------- COMPETITION --------------------------
model Competition {
  id                   Int       @id @default(autoincrement())
  title                String
  fromDate             DateTime
  toDate               DateTime
  date                 DateTime?
  location             String
  mainImageBase64      String    @db.LongText
  galleryImagesBase64  Json?
  galleryMedia         Json?     // Array of { type: 'image' | 'video', url: string }
  description          String    @default("") @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([fromDate])
  @@map("competitions")
}

// -------------------------- NATIONAL GALLERY EVENT --------------------------
model NationalGalleryEvent {
  id              Int      @id @default(autoincrement())
  title           String
  date            DateTime
  mainImageBase64 String   @db.LongText
  galleryMedia    Json?    // Array of { type: 'image' | 'video', url: string }
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
  @@map("national_gallery_events")
}

// -------------------------- PRESS RELEASE --------------------------
model PressRelease {
  id        Int      @id @default(autoincrement())
  title     String
  date      DateTime @default(now())
  pdfBase64 String   @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@map("press_releases")
}

// -------------------------- NATIONAL RECORD --------------------------
model NationalRecord {
  id        Int      @id @default(autoincrement())
  year      Int
  title     String
  pdfBase64 String   @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([year])
  @@map("national_records")
}

// -------------------------- PAST RESULT RECORD --------------------------
model PastResultRecord {
  id        Int       @id @default(autoincrement())
  title     String
  date      DateTime?
  location  String?
  matches   Json
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([createdAt])
  @@map("past_result_records")
}

// -------------------------- BLOG / NEWS ARTICLE --------------------------
model Blog {
  id               Int      @id @default(autoincrement())
  title            String
  slug             String   @unique
  date             DateTime @default(now())
  imageBase64      String   @db.LongText
  shortDescription String   @db.Text
  content          String   @db.LongText
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isActive, date])
  @@map("blogs")
}

// -------------------------- LATEST NEWS --------------------------
model LatestNews {
  id        Int      @id @default(autoincrement())
  title     String
  date      DateTime @default(now())
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, date])
  @@map("latest_news")
}

// -------------------------- EVENT REGISTRATION --------------------------
model EventRegistration {
  id                      Int      @id @default(autoincrement())
  eventId                 Int
  event                   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  firstName               String
  lastName                String
  fatherName              String
  religion                String
  dateOfBirth             DateTime
  profession              String
  addressLine1            String
  city                    String
  state                   String
  phoneNo                 String
  email                   String
  cnicNo                  String
  cnicCopyBase64          String   @db.LongText
  passportNo              String?  @default("")
  passportCopyBase64      String?  @db.LongText
  weapons                 Json
  weaponLicenseCopyBase64 String   @db.LongText
  bankChallanCopyBase64   String   @db.LongText
  status                  String   @default("pending")
  submittedAt             DateTime @default(now())
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([eventId])
  @@map("event_registrations")
}

// -------------------------- MEMBERSHIP APPLICATION --------------------------
model MembershipApplication {
  id                      Int      @id @default(autoincrement())
  membershipPlan          String
  firstName               String
  lastName                String
  fatherName              String
  religion                String
  dateOfBirth             DateTime
  profession              String
  addressLine1            String
  city                    String
  state                   String
  jobBusinessAddress      String   @db.Text
  presentHomeAddress      String   @db.Text
  permanentHomeAddress    String   @db.Text
  cnicNo                  String
  cnicCopyBase64          String   @db.LongText
  passportNo              String?  @default("")
  passportCopyBase64      String?  @db.LongText
  phoneNo                 String
  email                   String
  weapons                 Json
  weaponLicenseCopyBase64 String   @db.LongText
  membershipFeeYear       String
  bankChallanCopyBase64   String   @db.LongText
  status                  String   @default("pending")
  submittedAt             DateTime @default(now())
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("membership_applications")
}

// -------------------------- TESTIMONIAL --------------------------
model Testimonial {
  id          Int      @id @default(autoincrement())
  name        String
  designation String   @default("")
  message     String   @db.Text
  imageUrl    String?  @db.Text
  rating      Int      @default(5)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@map("testimonials")
}

// -------------------------- ACHIEVEMENT (International Ascendancy) ---
model Achievement {
  id        Int      @id @default(autoincrement())
  year      String   @default("")
  title     String
  bullets   Json // Array<{ text: string; children?: string[] }>
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@map("achievements")
}

// -------------------------- HISTORY (Long-Range Shooting in Pakistan) ---
model HistorySection {
  id        Int      @id @default(autoincrement())
  year      String   @default("")
  title     String   @default("")
  intro     String   @default("") @db.Text
  iconName  String   @default("")
  bullets   Json // Array<{ text: string; children?: string[] }>
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@map("history_sections")
}

// -------------------------- CONTRIBUTOR (Major Contributors) ---------
model Contributor {
  id            Int      @id @default(autoincrement())
  name          String
  role          String   @default("")
  contributions Json // string[]
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([sortOrder])
  @@map("contributors")
}

// -------------------------- SITE SETTINGS --------------------------
model SiteSettings {
  id                Int      @id @default(autoincrement())
  address           String   @default("Pakistan Long Range Rifle Association C/O Army Marksmanship Unit Jhelum Cantonment") @db.Text
  contactNo         String   @default("0092-544-620081")
  email             String   @default("plra.pakistan2022@gmail.com")
  workingHours      String   @default("Monday to Friday: 7am – 7pm")
  facebookLink      String   @default("https://facebook.com") @db.Text
  instagramLink     String   @default("https://instagram.com") @db.Text
  isMaintenanceMode Boolean  @default(false)
  plraIntro         String   @default("") @db.Text
  stats             Json?
  championMoments   Json?
  heroSlides        Json?
  aims              Json? // Array<{ title: string; description: string; iconName?: string }>
  accountDetails    Json? // { bankName, accountTitle, accountNumber, iban, branchCode }
  constitutionPdfBase64 String? @db.LongText
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("site_settings")
}

// -------------------------- CONTACT SUBMISSION --------------------------
model ContactSubmission {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@map("contact_submissions")
}